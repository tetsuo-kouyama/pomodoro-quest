<% content_for(:title, "モンスター雇用") %>

<div class="max-w-xl mx-auto my-10 bg-white p-10 rounded-2xl shadow-xl border border-gray-100">

  <div class="text-center mb-8">
    <h2 class="text-3xl font-black text-gray-800 tracking-wide">モンスターを雇用する</h2>
  </div>

  <%= render "form", owned_monster: @owned_monster, monsters: @monsters %>

  <div class="text-center mt-6">
    <%= link_to "← 街に戻る", owned_monsters_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" %>
  </div>

</div>
