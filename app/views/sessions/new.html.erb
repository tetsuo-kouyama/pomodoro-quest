<% content_for(:title, "ログイン") %>

<div class="auth-container">
  <h1 class="auth-title">ログイン</h1>

  <%= form_with scope: :session, url: login_path, class: "auth-form" do |f| %>
    <div class="form-group">
      <%= f.label :email, "メールアドレス", class: "form-label" %>
      <%= f.email_field :email, class: "form-input", placeholder: "example@email.com", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :password, "パスワード", class: "form-label" %>
      <%= f.password_field :password, class: "form-input", required: true %>
    </div>

    <div class="form-actions">
      <%= f.submit "ログイン", class: "auth-button" %>
    </div>
  <% end %>

  <div class="auth-link">
    <%= link_to "新規登録ページへ", new_user_path %>
  </div>
</div>
