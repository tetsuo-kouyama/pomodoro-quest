<% content_for(:title, "作戦準備") %>

<%= render "shared/upper_navigation" %>

<div class="p-5 space-y-6">

  <%# --- パーティ確認エリア --- %>
  <%= link_to edit_party_path, class: "block no-underline" do %>
    <div class="bg-white p-4 rounded-xl border-2 border-slate-800 shadow-[2px_2px_0_rgba(15,23,42,1)] hover:bg-slate-50 transition-all">

      <div class="flex justify-between items-center mb-3">
        <span class="text-xs font-black text-slate-400">現在のパーティ</span>
        <span class="text-xs font-black text-fuchsia-500 bg-fuchsia-50 px-2 py-0.5 rounded border border-fuchsia-200">編成する →</span>
      </div>

      <div class="space-y-1.5 pl-1">
        <% (1..OwnedMonster::MAX_PARTY_SIZE).each do |i| %>
          <% active_monster = monster_in_slot(@active_monsters, i) %>
          <div class="flex items-center gap-3 font-black text-xs text-slate-700">
            <span class="text-slate-400 text-[10px] bg-slate-100 px-1.5 py-0.5 rounded border border-slate-200 w-5 text-center"><%= i %></span>
            <span><%= active_monster&.nickname || "（空きスロット）" %></span>
          </div>
        <% end %>
      </div>

    </div>
  <% end %>


  <%# --- フォームエリア --- %>
  <%= form_with model: @adventure do |f| %>

    <div class="bg-white p-5 rounded-xl border-2 border-slate-800 shadow-[2px_2px_0_rgba(15,23,42,1)] space-y-4 font-black text-slate-800">

      <%# ダンジョン選択 %>
      <div>
        <%= f.label :dungeon_id, "ダンジョン", class: "block text-xs text-slate-400 mb-1" %>
        <%= f.collection_select :dungeon_id, @dungeons, :id, ->(d) { "#{d.name} (難易度: #{d.difficulty})" },
              { prompt: "ダンジョンを選択してください" },
              { required: true, class: "p-3 bg-slate-50 border-2 border-slate-800 rounded-lg text-sm w-full cursor-pointer" } %>
      </div>

      <%# 冒険時間選択 %>
      <div>
        <%= f.label :required_time, "冒険時間", class: "block text-xs text-slate-400 mb-1" %>
        <%# 選択のプロンプトを「時間を〜」に修正、w-full を追加 %>
        <%= f.select :required_time,
              @required_times.map { |time|
                ["#{time / 60}分", time]
              },
              { prompt: "時間を選択してください" },
              { required: true, class: "p-3 bg-slate-50 border-2 border-slate-800 rounded-lg text-sm w-full cursor-pointer" } %>
      </div>

    </div>

    <%# 冒険するボタン %>
    <%# 修正：不要な '#' を削除 %>
    <div class="text-center pt-4">
      <%= f.submit "冒険する", class: "w-full py-4 bg-fuchsia-300 text-slate-800 font-black rounded-xl border-2 border-slate-800 border-b-4 shadow-md active:translate-y-0.5 active:border-b-2 active:shadow-sm transition-all cursor-pointer" %>
    </div>

  <% end %>

</div>
